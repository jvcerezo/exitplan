{
  "expo": {
    "name": "ExitPlan",
    "slug": "exitplan",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "exitplan",
    "platforms": ["ios", "android"],
    "assetBundlePatterns": ["**/*"],
    "plugins": [
      "expo-router"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jvcerezo.exitplan"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "package": "com.jvcerezo.exitplan"
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
